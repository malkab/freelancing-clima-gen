{
  "dockerComposeFile": "docker-compose.yml",
  "service": "python",
  "workspaceFolder": "/workspace/",
  "name": "freelancing-clima-gen-python",
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        // Carga de extensiones según su ID
        // que se puede obtener en el propio
        // panel de extensiones de VSC
      ],
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash",
      },
    },
  },
  "remoteUser": "vscode",
  "containerEnv": {
    "PYTHONPATH": "/workspace/src:/workspace/tests",
    "PATH": "${localEnv:PATH}:/home/vscode/.local/bin:/usr/local/bin",
  },
  // Este es un buen lugar para cambiar permisos de carpetas.
  // "postCreateCommand": "sudo chown -R vscode:vscode /ssparc",

  // Ejemplo de ejecución de script de post creación.
  // "postCreateCommand": "./.devcontainer/assets/postcreatecommand.sh"

  // Un buen lugar para ejecutar comandos de
  // post-inicialización.
  // "initializeCommand": "echo POST_INIT"
}
