{
    "version": 8,
    "name": "OpenStreetMap Raster Base",
    "metadata": {},
    "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
    "sources": {
        "maplibre": {
            "url": "https://demotiles.maplibre.org/tiles/tiles.json",
            "type": "vector"
        },
        "openstreetmap": {
            "type": "raster",
            "tiles": [
                "https://tile.openstreetmap.org/{z}/{x}/{y}.png"
            ],
            "tileSize": 256,
            "minzoom": 0,
            "maxzoom": 22,
            "attribution": "© OpenStreetMap contributors"
        },

        "autonomia_area": {
            "type": "vector",
            "tiles": [
                "http://localhost:5173/martin/autonomia/{z}/{x}/{y}"
            ],
            "minzoom": 0,
            "maxzoom": 22
        },
        "autonomia_borde": {
            "type": "vector",
            "tiles": [
                "http://localhost:5173/martin/autonomia.1/{z}/{x}/{y}"
            ],
            "minzoom": 0,
            "maxzoom": 22
        },
        "autonomia_centroid": {
            "type": "vector",
            "tiles": [
                "http://localhost:5173/martin/autonomia.2/{z}/{x}/{y}"
            ],
            "minzoom": 0,
            "maxzoom": 22
        },

        "provincia_area": {
            "type": "vector",
            "tiles": [
                "http://localhost:5173/martin/provincia/{z}/{x}/{y}"
            ],
            "minzoom": 0,
            "maxzoom": 22
        },
        "provincia_borde": {
            "type": "vector",
            "tiles": [
                "http://localhost:5173/martin/provincia.1/{z}/{x}/{y}"
            ],
            "minzoom": 0,
            "maxzoom": 22
        },
        "provincia_centroid": {
            "type": "vector",
            "tiles": [
                "http://localhost:5173/martin/provincia.2/{z}/{x}/{y}"
            ],
            "minzoom": 0,
            "maxzoom": 22
        },

        "municipio_area": {
            "type": "vector",
            "tiles": [
                "http://localhost:5173/martin/municipio/{z}/{x}/{y}"
            ],
            "minzoom": 0,
            "maxzoom": 22
        },
        "municipio_borde": {
            "type": "vector",
            "tiles": [
                "http://localhost:5173/martin/municipio.1/{z}/{x}/{y}"
            ],
            "minzoom": 0,
            "maxzoom": 22
        },
        "municipio_centroid": {
            "type": "vector",
            "tiles": [
                "http://localhost:5173/martin/municipio.2/{z}/{x}/{y}"
            ],
            "minzoom": 0,
            "maxzoom": 22
        }
    },

    "layers": [
        {
            "id": "background",
            "type": "background",
            "paint": {
                "background-color": "#ffffff"
            },
            "filter": [
                "all"
            ],
            "layout": {
                "visibility": "visible"
            },
            "maxzoom": 24
        },

        {
            "id": "openstreetmap",
            "type": "raster",
            "source": "openstreetmap",
            "metadata": {
                "group": "base",
                "name": "OpenStreetMap"
            },
            "layout": {
                "visibility": "visible"
            }
        },

        {
            "id": "variables",
            "type": "background",
            "layout": {
                "visibility": "none"
            }
        }

    ]
}